# Development Dockerfile for Angular Frontend
FROM node:18-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Install dependencies
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Expose Angular dev server port
EXPOSE 4200

# Labels for metadata
LABEL maintainer="Psychology Assistant Team"
LABEL description="Psychology Assistant Frontend - Development"
LABEL version="0.3.0"

# Health check (check dev server)
# Note: Using curl instead of wget as it's available in node alpine
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD node -z "$(curl -s http://localhost:4200/ | grep -o '<app-root' | head -1)" || exit 1

# Run Angular dev server with polling for container compatibility
CMD ["pnpm", "start"]
