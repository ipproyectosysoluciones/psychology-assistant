{
  "name": "psychology-assistant",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "echo 'Build completed - ES modules ready'",
    "docker:build": "docker build -t psychology-assistant .",
    "docker:run": "docker run -p 5000:5000 psychology-assistant",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose up -d",
    "db:seed": "node scripts/seed.js",
    "precommit": "pnpm run lint && pnpm run test",
    "prepare": "husky install || true"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.3.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "xss": "^1.0.15"
  },
  "eslintConfig": {},
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "semistandard": "^17.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6"
  }
}
