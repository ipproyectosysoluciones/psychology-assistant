# Application
NODE_ENV=development
PORT=5000

# Database Configuration
# For development: Set DATABASE_URL to use real MongoDB
# If DATABASE_URL is not set, uses in-memory MongoDB (faster startup)
# Examples:
#   Local:  mongodb://localhost:27017/psychology-assistant
#   Atlas:  mongodb+srv://username:password@cluster.mongodb.net/psychology-assistant
DATABASE_URL=mongodb://localhost:27017/psychology-assistant

# Fallback for production (if DATABASE_URL not set)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/psychology-assistant

# JWT Configuration  
JWT_SECRET=your_super_secure_secret_key_change_this_in_production
JWT_EXPIRE=7d

# 2FA Configuration
TWO_FA_WINDOW=2

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_change_this
SESSION_TIMEOUT=3600000