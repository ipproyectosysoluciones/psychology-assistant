################################################################################
# PSYCHOLOGY ASSISTANT - ENVIRONMENT CONFIGURATION
################################################################################
# 
# ES: Archivo de configuración de variables de entorno
#     Copia este archivo a .env y reemplaza los valores según tu entorno
#
# EN: Environment variables configuration file
#     Copy this file to .env and replace values according to your environment
#
################################################################################

# =============================================================================
# APPLICATION SERVER
# =============================================================================

# ES: Entorno de ejecución (development|test|production)
# EN: Execution environment (development|test|production)
# DEFAULT: development
NODE_ENV=development

# ES: Puerto donde corre la aplicación
# EN: Port where the application runs
# DEFAULT: 5000
# EXAMPLE: 3000, 8080, 5000
PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# ES: URL de conexión a MongoDB
#     - Para desarrollo local: mongodb://localhost:27017/psychology-assistant
#     - Para MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/psychology-assistant
#     - Si no está definido en desarrollo, usa base de datos en memoria (más rápido)
#
# EN: MongoDB connection URL
#     - For local development: mongodb://localhost:27017/psychology-assistant
#     - For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/psychology-assistant
#     - If not defined in dev, uses in-memory database (faster)
#
# REQUIRED IN: production
# DEFAULT: mongodb://localhost:27017/psychology-assistant
DATABASE_URL=mongodb://localhost:27017/psychology-assistant

# ES: URI alternativa de MongoDB (usado como fallback)
# EN: Alternative MongoDB URI (used as fallback)
# REQUIRED IN: production
# NOTE: Use DATABASE_URL primarily, MONGO_URI is fallback only
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/psychology-assistant

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# ES: Clave secreta para firmar tokens JWT
#     IMPORTANTE: Usar una cadena larga y aleatoria en producción
#     Recomendación: openssl rand -base64 32
#
# EN: Secret key for signing JWT tokens
#     IMPORTANT: Use a long, random string in production
#     Recommendation: openssl rand -base64 32
#
# REQUIRED: YES (validation in code)
# SECURITY: Change in production, use minimum 32 characters
JWT_SECRET=your_super_secure_secret_key_change_this_in_production_min_32_chars

# ES: Tiempo de expiración del token JWT
# EN: JWT token expiration time
# DEFAULT: 7d (7 days)
# FORMAT: Time string (e.g., 7d, 24h, 1440m, 86400s)
# ALLOWED: 1d-30d for production
JWT_EXPIRE=7d

# ES: Clave secreta para sesiones de usuario
#     IMPORTANTE: Usar una cadena larga y aleatoria en producción
#
# EN: Secret key for user sessions
#     IMPORTANT: Use a long, random string in production
#
# REQUIRED: YES
# SECURITY: Change in production
SESSION_SECRET=your_session_secret_change_this_in_production_min_32_chars

# ES: Duración de la sesión en milisegundos
# EN: Session timeout in milliseconds
# DEFAULT: 3600000 (1 hour = 3600000ms)
# EXAMPLES: 
#   600000 = 10 minutes
#   1800000 = 30 minutes
#   3600000 = 1 hour
#   86400000 = 1 day
SESSION_TIMEOUT=3600000

# =============================================================================
# TWO-FACTOR AUTHENTICATION (2FA)
# =============================================================================

# ES: Ventana de tolerancia para tokens TOTP en pasos de tiempo
#     Permite códigos de hace N pasos de tiempo (cada paso = 30 segundos)
#     2 = permite códigos hasta 60 segundos atrás (normal)
#
# EN: Tolerance window for TOTP tokens in time steps
#     Allows codes from N time steps ago (each step = 30 seconds)
#     2 = allows codes up to 60 seconds old (standard)
#
# DEFAULT: 2 (60 seconds tolerance)
# ALLOWED: 0-3 (0=strict, 3=very lenient)
TWO_FA_WINDOW=2

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# ES: Nivel de logging (error|warn|info|debug|verbose)
# EN: Logging level (error|warn|info|debug|verbose)
# DEFAULT: info
# RECOMMENDED:
#   development: debug
#   production: warn or info
#   testing: error
LOG_LEVEL=debug

# =============================================================================
# CORS - CROSS-ORIGIN RESOURCE SHARING
# =============================================================================

# ES: Origen permitido para peticiones CORS
#     Define qué dominios pueden hacer peticiones a esta API
#     Para múltiples orígenes en producción, usar middleware personalizado
#
# EN: Allowed origin for CORS requests
#     Defines which domains can make requests to this API
#     For multiple origins in production, use custom middleware
#
# DEFAULT: http://localhost:3000
# EXAMPLES:
#   development: http://localhost:3000, http://localhost:4200
#   production: https://yourdomain.com, https://app.yourdomain.com
#   multiple: Use custom CORS middleware
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# ES: URL de la aplicación frontend
#     Usado por componentes para redireccionamientos después de acciones
#
# EN: Frontend application URL
#     Used by components for redirects after actions
#
# DEFAULT: http://localhost:3000 (development)
# EXAMPLES:
#   development: http://localhost:3000 or http://localhost:4200
#   production: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# ES: URL base de la API (sin trailing slash)
#     Configurado en environment.ts del frontend
#
# EN: API base URL (no trailing slash)
#     Configured in environment.ts in frontend
#
# DEFAULT: http://localhost:5000/api
# EXAMPLES:
#   development: http://localhost:5000/api
#   production: https://api.yourdomain.com/api
API_URL=http://localhost:5000/api

# =============================================================================
# OPTIONAL: ADVANCED FEATURES
# =============================================================================

# ES: Email para notificaciones (futuro)
# EN: Email for notifications (future)
# OPTIONAL: Not yet implemented
# EMAIL_SERVICE_PASSWORD=

# ES: Clave de API para servicios externo (futuro)
# EN: API key for external services (future)
# OPTIONAL: Not yet implemented
# EXTERNAL_API_KEY=

################################################################################
# SETUP & VALIDATION NOTES
# ===============================================================================
#
# 🔒 PRODUCTION SECURITY CHECKLIST:
# 
#   ES: 
#     1. Cambiar JWT_SECRET a una cadena aleatoria de 32+ caracteres
#     2. Cambiar SESSION_SECRET a una cadena aleatoria de 32+ caracteres
#     3. Usar DATABASE_URL con credenciales seguras de MongoDB Atlas
#     4. Establecer NODE_ENV=production
#     5. Usar HTTPS en CORS_ORIGIN (https://...)
#     6. Cambiar LOG_LEVEL a 'warn' o 'info'
#     7. Verificar SESSION_TIMEOUT según políticas de seguridad
#
#   EN:
#     1. Change JWT_SECRET to a random string of 32+ characters
#     2. Change SESSION_SECRET to a random string of 32+ characters
#     3. Use DATABASE_URL with secure MongoDB Atlas credentials
#     4. Set NODE_ENV=production
#     5. Use HTTPS in CORS_ORIGIN (https://...)
#     6. Change LOG_LEVEL to 'warn' or 'info'
#     7. Verify SESSION_TIMEOUT according to security policies
#
# 🔧 LOCAL DEVELOPMENT SETUP:
#
#   ES: Si usas MongoDB localmente:
#       1. Instala MongoDB Community Edition
#       2. Ejecuta: mongod
#       3. Usa DATABASE_URL=mongodb://localhost:27017/psychology-assistant
#
#   EN: If using MongoDB locally:
#       1. Install MongoDB Community Edition
#       2. Run: mongod
#       3. Use DATABASE_URL=mongodb://localhost:27017/psychology-assistant
#
# 📚 DOCUMENTATION:
#   See ENVIRONMENT_SETUP.md for detailed setup guide
#
################################################################################