                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Clínica Psicología Integral\",\n  \"email\": \"info@clinica.com\",\n  \"phone\": \"+57 1 234 5678\",\n  \"address\": \"Cra. 5 #45-27\",\n  \"city\": \"Bogotá\",\n  \"country\": \"Colombia\",\n  \"postalCode\": \"110111\",\n  \"currency\": \"COP\",\n  \"website\": \"https://www.clinica.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clinics",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clinics"]
            }
          }
        },
        {
          "name": "Get Clinic",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/clinics/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "clinics", ":id"]
            }
          }
        }
      ]
    },
